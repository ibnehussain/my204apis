<!--
  APIM Policy: Request / Response Transform
  Applied at: API level (inbound + outbound)

  Inbound:
    - Strips the Authorization header before forwarding to backend
      (backend trusts the network; APIM is the auth boundary)
    - Sets backend host header dynamically

  Outbound:
    - Removes internal Server header from responses
    - Adds standard CORS + security headers
-->
<policies>
  <inbound>
    <base />
    <!-- Forward to App Service backend -->
    <set-backend-service base-url="https://{{backend-app-service-url}}/api" />
    <!-- Remove auth header — backend is protected by VNET/internal routing -->
    <set-header name="Authorization" exists-action="delete" />
    <!-- Stamp a correlation ID for tracing -->
    <set-header name="X-Correlation-Id" exists-action="override">
      <value>@(context.RequestId)</value>
    </set-header>
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <!-- Remove server fingerprint -->
    <set-header name="Server" exists-action="delete" />
    <set-header name="X-Powered-By" exists-action="delete" />
    <!-- Security headers -->
    <set-header name="X-Content-Type-Options" exists-action="override">
      <value>nosniff</value>
    </set-header>
    <set-header name="X-Frame-Options" exists-action="override">
      <value>DENY</value>
    </set-header>
    <set-header name="Strict-Transport-Security" exists-action="override">
      <value>max-age=31536000; includeSubDomains</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
