# Azure Cosmos DB
# No key needed — authentication is via Managed Identity (on Azure App Service)
# or Azure CLI credentials (local development).
# Run: az login   before starting the server locally.
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_DATABASE_ID=my204db
COSMOS_CONTAINER_ID=items

# App Service
PORT=3000

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://...
