@model Demo.Web.Models.Item
@{
    ViewData["Title"] = Model?.Name ?? "Item Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="display-4">Item Details</h1>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary me-2">
                        <i class="fas fa-list"></i> Back to Items
                    </a>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">
                        <i class="fas fa-home"></i> Home
                    </a>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    @ViewBag.Error
                </div>
                <div class="text-center py-5">
                    <div class="display-1 text-muted mb-3">
                        <i class="fas fa-search-minus"></i>
                    </div>
                    <h3 class="text-muted">Item Not Found</h3>
                    <p class="lead text-muted">The requested item could not be found or there was an error loading the details.</p>
                </div>
            }
            else if (Model != null)
            {
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <div class="card shadow-lg">
                            <div class="card-header bg-primary text-white">
                                <h2 class="card-title mb-0">@Model.Name</h2>
                            </div>
                            <div class="card-body">
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <h5 class="text-muted">Description</h5>
                                        <p class="lead">@Model.Description</p>
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="text-muted">Category</h5>
                                        <span class="badge bg-secondary fs-6 mb-3">@Model.Category</span>
                                        
                                        <h5 class="text-muted">Price</h5>
                                        <h3 class="text-success">$@Model.Price.ToString("F2")</h3>
                                    </div>
                                </div>

                                <hr>

                                <div class="row">
                                    <div class="col-md-4">
                                        <small class="text-muted">Item ID:</small><br>
                                        <code>@Model.Id</code>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted">Created:</small><br>
                                        <span>@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' h:mm tt")</span>
                                    </div>
                                    <div class="col-md-4">
                                        <small class="text-muted">Last Updated:</small><br>
                                        <span>@Model.LastModified.ToString("MMMM dd, yyyy 'at' h:mm tt")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <a href="@Url.Action("Category", new { category = Model.Category })" 
                                       class="btn btn-outline-primary">
                                        <i class="fas fa-filter"></i> More in @Model.Category
                                    </a>
                                    <div>
                                        <button class="btn btn-success" onclick="shareItem()">
                                            <i class="fas fa-share"></i> Share
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function shareItem() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model?.Name',
                    text: '@Model?.Description',
                    url: window.location.href
                });
            } else {
                // Fallback: copy URL to clipboard
                navigator.clipboard.writeText(window.location.href).then(function() {
                    alert('Item URL copied to clipboard!');
                });
            }
        }
    </script>
}